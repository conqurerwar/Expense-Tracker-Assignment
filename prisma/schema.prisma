generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String               @id @default(uuid())
  email                 String               @unique
  password              String?              // Optional for backwards compatibility, required for new users
  name                  String
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  
  // Relationships
  memberships           GroupMember[]
  expensesPaid          Expense[]            @relation("ExpensesPaid")
  expenseSplits         ExpenseSplit[]
  expensesParticipated  ExpenseParticipant[]
  settlementsPaid       Settlement[]         @relation("SettlementsPaid")
  settlementsReceived   Settlement[]         @relation("SettlementsReceived")
  auditLogs             AuditLog[]
}

model Group {
  id          String        @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  // Relationships
  members     GroupMember[]
  expenses    Expense[]
  settlements Settlement[]
}

model GroupMember {
  id        String    @id @default(uuid())
  groupId   String
  userId    String
  joinedAt  DateTime
  leftAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  
  // Relationships
  group     Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model Expense {
  id               String               @id @default(uuid())
  groupId          String
  description      String
  paidById         String
  amount           Float                // Amount in base currency (INR)
  originalAmount   Float                // Original amount before conversion
  originalCurrency String               // Original currency (USD, INR, etc.)
  exchangeRate     Float                @default(1.0)
  exchangeRateId   String?
  splitType        String               // equal, unequal, percentage, share
  notes            String?
  date             DateTime
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  importId         String?
  
  // Relationships
  group            Group                @relation(fields: [groupId], references: [id], onDelete: Cascade)
  paidBy           User                 @relation("ExpensesPaid", fields: [paidById], references: [id], onDelete: Cascade)
  import           Import?              @relation(fields: [importId], references: [id], onDelete: SetNull)
  participants     ExpenseParticipant[]
  splits           ExpenseSplit[]
}

model ExpenseParticipant {
  id        String  @id @default(uuid())
  expenseId String
  userId    String
  
  // Relationships
  expense   Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([expenseId, userId])
}

model ExpenseSplit {
  id               String   @id @default(uuid())
  expenseId        String
  userId           String
  amount           Float    // Allocated share in base currency (INR)
  originalAmount   Float    // Allocated share in original currency
  ratio            Float?   // Ratio/shares (e.g. 1, 2) if splitType is share
  percentage       Float?   // Percentage (e.g. 30%) if splitType is percentage
  
  // Relationships
  expense          Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([expenseId, userId])
}

model Settlement {
  id               String   @id @default(uuid())
  groupId          String
  payerId          String
  payeeId          String
  amount           Float    // Settled amount in base currency (INR)
  originalAmount   Float    // Original settled amount
  originalCurrency String   // Original currency (USD, INR)
  exchangeRate     Float    @default(1.0)
  date             DateTime
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  importId         String?
  
  // Relationships
  group            Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payer            User     @relation("SettlementsPaid", fields: [payerId], references: [id], onDelete: Cascade)
  payee            User     @relation("SettlementsReceived", fields: [payeeId], references: [id], onDelete: Cascade)
  import           Import?  @relation(fields: [importId], references: [id], onDelete: SetNull)
}

model Import {
  id             String        @id @default(uuid())
  fileName       String
  status         String        // PENDING, COMPLETED, FAILED
  rowsProcessed  Int           @default(0)
  rowsImported   Int           @default(0)
  warningsCount  Int           @default(0)
  errorsCount    Int           @default(0)
  createdAt      DateTime      @default(now())
  
  // Relationships
  issues         ImportIssue[]
  expenses       Expense[]
  settlements    Settlement[]
}

model ImportIssue {
  id                String    @id @default(uuid())
  importId          String
  rowIndex          Int
  issueType         String
  confidence        Float
  affectedRowData   String    @db.Text  // JSON string representation of original row
  description       String    @db.Text
  recommendedAction String    @db.Text
  userDecision      String    // APPLY_FIX, IMPORT_AS_IS, SKIP_ROW, MANUAL_EDIT
  finalResolution   String?   @db.Text  // Description of final resolution
  resolvedValue     String?   @db.Text  // JSON string of resolved/fixed data
  appliedAt         DateTime?
  createdAt         DateTime  @default(now())
  
  // Relationships
  import            Import    @relation(fields: [importId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  entityType String
  entityId   String
  oldValue   String?  @db.LongText // JSON string
  newValue   String?  @db.LongText // JSON string
  createdAt  DateTime @default(now())
  
  // Relationships
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model ExchangeRate {
  id            String   @id @default(uuid())
  fromCurrency  String
  toCurrency    String
  rate          Float
  effectiveDate DateTime
  createdAt     DateTime @default(now())
  
  @@unique([fromCurrency, toCurrency, effectiveDate])
}

